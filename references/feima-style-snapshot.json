  "article_base_css": "/* 文章正文排版 — 与 feima-lab 设计系统一致 */\n.article-content {\n  font-size: 1.0625rem;\n  line-height: 1.8;\n  color: #1A1A1A;\n}\n\n.article-content h1,\n.article-content h2,\n.article-content h3,\n.article-content h4 {\n  font-weight: 600;\n  line-height: 1.4;\n  margin-top: 2em;\n  margin-bottom: 0.75em;\n}\n\n.article-content h1 { font-size: 1.75rem; }\n.article-content h2 { font-size: 1.5rem; }\n.article-content h3 { font-size: 1.25rem; }\n.article-content h4 { font-size: 1.125rem; }\n\n.article-content p {\n  margin-bottom: 1.25em;\n}\n\n.article-content a {\n  color: #D4845A;\n  text-decoration: underline;\n  text-underline-offset: 2px;\n}\n.article-content a:hover {\n  color: #C07548;\n}\n\n.article-content img {\n  max-width: 100%;\n  height: auto;\n  border-radius: 16px;\n  margin: 1.5em 0;\n}\n\n.article-content blockquote {\n  border-left: 3px solid #D4845A;\n  padding: 0.5em 1em;\n  margin: 1.5em 0;\n  background: #FDF8EE;\n  border-radius: 0 10px 10px 0;\n  color: #6B6560;\n}\n\n.article-content pre {\n  background: #1A1A1A;\n  color: #FAF9F6;\n  padding: 1.25em 1.5em;\n  border-radius: 16px;\n  overflow-x: auto;\n  margin: 1.5em 0;\n  font-size: 0.875rem;\n  line-height: 1.6;\n}\n\n.article-content code {\n  background: #F3F1ED;\n  padding: 0.15em 0.4em;\n  border-radius: 6px;\n  font-size: 0.875em;\n}\n\n.article-content pre code {\n  background: none;\n  padding: 0;\n  border-radius: 0;\n  font-size: inherit;\n}\n\n.article-content ul,\n.article-content ol {\n  padding-left: 1.5em;\n  margin-bottom: 1.25em;\n}\n\n.article-content li {\n  margin-bottom: 0.5em;\n}\n\n.article-content ul li { list-style-type: disc; }\n.article-content ol li { list-style-type: decimal; }\n\n.article-content table {\n  width: 100%;\n  border-collapse: collapse;\n  margin: 1.5em 0;\n  font-size: 0.9375rem;\n}\n\n.article-content th,\n.article-content td {\n  border: 1px solid #E8E5E0;\n  padding: 0.75em 1em;\n  text-align: left;\n}\n\n.article-content th {\n  background: #F3F1ED;\n  font-weight: 600;\n}\n\n.article-content hr {\n  border: none;\n  border-top: 1px solid #E8E5E0;\n  margin: 2em 0;\n}\n\n/* 视频嵌入 */\n.article-content iframe {\n  max-width: 100%;\n  border-radius: 16px;\n  margin: 1.5em 0;\n}\n",
