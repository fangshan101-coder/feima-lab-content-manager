{
  "$schema_version": "1.0",
  "tokens": {
    "colors": { "brand": "#D4845A", "bg-primary": "#FAF9F6" },
    "radius": { "md": "16px" },
    "fonts": { "sans": "'Inter', sans-serif" }
  },
  "article_base_css": ".article-content{color:#1A1A1A}",
  "components": {
    "Callout": {
      "variants": {
        "tip": { "bg": "#EFF6F0", "border": "#4ade80", "icon": "💡" },
        "warning": { "bg": "#FDF8EE", "border": "#fbbf24", "icon": "⚠️" },
        "info": { "bg": "#EEF4FA", "border": "#60a5fa", "icon": "ℹ️" },
        "error": { "bg": "#FAF0F0", "border": "#f87171", "icon": "❌" }
      },
      "static_styles": { "container": "", "header": "", "body": "" },
      "interactive": false
    },
    "Collapse": {
      "static_styles": {
        "wrapper": "", "header": "", "icon": "", "body": ""
      },
      "interactive": true,
      "js_behavior_key": "collapse"
    },
    "CodeTabs": { "static_styles": { "wrapper": "", "tab_bar": "", "tab": "", "tab_active": "", "panel": "" }, "interactive": true, "js_behavior_key": "code-tabs" },
    "CompareCard": { "static_styles": { "grid": "", "card": "", "card_left_bg": "", "card_right_bg": "", "title": "", "list": "", "list_item": "" } },
    "Timeline": { "static_styles": { "wrapper": "", "step": "", "step_number": "", "step_connector": "", "step_content": "", "step_title": "", "step_desc": "" } },
    "ImageCarousel": { "static_styles": { "wrapper": "", "frame": "", "image": "", "nav_button": "", "nav_button_prev": "", "nav_button_next": "", "caption": "", "dots": "", "dot": "", "dot_active": "" }, "interactive": true, "js_behavior_key": "image-carousel" },
    "Playground": { "static_styles": { "wrapper": "", "title_bar": "", "title_text": "", "button_group": "", "button_copy": "", "button_run": "", "code_area": "", "output_area": "" }, "interactive": true, "js_behavior_key": "playground" }
  }
}
